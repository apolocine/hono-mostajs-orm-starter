# Defaults to sqljs (SQLite WASM) in-memory — no setup needed, boots anywhere.
# Switch DB without touching code:
#   DB_DIALECT=sqlite  DATABASE_URL=./blog.db    # local Node (npm i better-sqlite3)
#   DB_DIALECT=pglite  DATABASE_URL=idb://blog   # Postgres WASM, browser-persistent
PORT=3000
ORM_SEED_ON_BOOT=1
